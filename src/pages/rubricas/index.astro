---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getRubricaIndexes, splitId } from '../../lib/rubricas';

const indexes = await getRubricaIndexes();
---
<BaseLayout title="Unusual Rubricas" description="Recurring themes from my diaries." bodyClass="rubricas-index">
  <h1>Unusual Rubricas</h1>

  <p class="rubricas-caption">
    These are the "unusual rubricas" written at the end of my diaries when you
    put them upside down. Some of them begin and ends with the life for that
    diaries, while some others I will bring with me into the next diary. If
    well read, they might include other side of myself.
  </p>

  {indexes.length === 0 ? (
    <p><em>No rubricas yet. Create a folder under <code>src/content/rubricas/</code>.</em></p>
  ) : (
    <ul class="entries">
      {indexes.map(idx => {
        const { rubrica } = splitId(idx.id);
        return (
          <li>
            <a href={`/rubricas/${rubrica}`}>{idx.data.title}</a>
            {idx.data.summary && <span class="muted">{idx.data.summary}</span>}
          </li>
        );
      })}
    </ul>
  )}
</BaseLayout>
